{
  "_version": "1.76.0",
  "sap.app": {
    "id": "bookshop.managebooksandorders",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "Manage Books and Orders",
    "description": "Manage Books and Orders",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.18.7",
      "toolsId": "521ed008-dc60-4aec-8b72-2725f1ec5a2c"
    },
    "dataSources": {
      "mainService": {
        "uri": "/service/CatalogService/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.0"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "managebooksandorders-display": {
          "semanticObject": "managebooksandorders",
          "action": "display",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.136.3",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "bookshop.managebooksandorders.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "BooksList",
          "target": [
            "BooksList"
          ]
        },
        {
          "pattern": "Books({key}):?query:",
          "name": "BooksObjectPage",
          "target": [
            "BooksList",
            "BooksObjectPage"
          ]
        },
        {
          "name": "OrdersObjectPage",
          "pattern": "Orders({OrdersKey}):?query:",
          "target": "OrdersObjectPage"
        }
      ],
      "targets": {
        "BooksList": {
          "type": "Component",
          "id": "BooksList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "enhanceI18n": "i18n/custom_i18n.properties",
              "contextPath": "/Books",
              "variantManagement": "Page",
              "navigation": {
                "Books": {
                  "detail": {
                    "route": "BooksObjectPage"
                  }
                },
                "Orders": {
                  "detail": {
                    "route": "OrdersObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable"
                  },
                  "columns": {
                    "DataField::title": {
                      "width": "100%"
                    },
                    "DataField::author": {
                      "width": "100%"
                    },
                    "DataField::price": {
                      "width": "100%"
                    },
                    "DataField::stock": {
                      "width": "100%"
                    },
                    "DataFieldForAnnotation::DataPoint::rating1": {
                      "width": "100%"
                    }
                  }
                },
                "/Orders/@com.sap.vocabularies.UI.v1.LineItem#tableView": {
                  "columns": {
                    "DataField::orderNumber": {
                      "width": "100%"
                    },
                    "DataField::status_code": {
                      "width": "100%"
                    },
                    "DataField::totalPrice": {
                      "width": "100%"
                    }
                  }
                }
              },
              "defaultTemplateAnnotationPath": "com.sap.vocabularies.UI.v1.SelectionPresentationVariant#tableView",
              "initialLoad": "Enabled",
              "views": {
                "paths": [
                  {
                    "key": "tableView",
                    "annotationPath": "com.sap.vocabularies.UI.v1.SelectionPresentationVariant#tableView"
                  },
                  {
                    "key": "tableView1",
                    "annotationPath": "com.sap.vocabularies.UI.v1.SelectionPresentationVariant#tableView",
                    "entitySet": "Orders"
                  }
                ]
              }
            }
          }
        },
        "BooksObjectPage": {
          "type": "Component",
          "id": "BooksObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "enhanceI18n": "i18n/custom_i18n.properties",
              "editableHeaderContent": false,
              "contextPath": "/Books"
            }
          }
        },
        "OrdersObjectPage": {
          "type": "Component",
          "id": "OrdersObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "enhanceI18n": "i18n/custom_i18n.properties",
              "navigation": {},
              "contextPath": "/Orders",
              "controlConfiguration": {
                "orderItems/@com.sap.vocabularies.UI.v1.LineItem#i18nOrderedItems": {
                  "columns": {
                    "DataField::book::title": {
                      "width": "100%"
                    },
                    "DataField::quantity": {
                      "width": "100%"
                    },
                    "DataField::book::author": {
                      "width": "100%"
                    },
                    "DataField::book::genre::name": {
                      "width": "100%"
                    },
                    "DataField::netprice": {
                      "width": "100%"
                    }
                  }
                },
                "orderlog/@com.sap.vocabularies.UI.v1.LineItem#OrderLog": {
                  "columns": {
                    "DataField::status_code": {
                      "width": "100%"
                    },
                    "DataField::trackingInfo": {
                      "width": "100%"
                    },
                    "DataField::modifiedAt": {
                      "width": "100%"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.fe": {
    "macros": {
      "table": {
        "defaultPopinLayout": "GridSmall"
      }
    }
  },
  "sap.cloud": {
    "public": true,
    "service": "CAPsample.service"
  }
}

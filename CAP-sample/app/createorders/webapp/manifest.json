{
  "_version": "1.76.0",
  "sap.app": {
    "id": "bookshop.createorders",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "Create Orders",
    "description": "Create Orders",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.18.7",
      "toolsId": "c3b329da-9f2f-4ea2-957b-2905b8411f7a"
    },
    "dataSources": {
      "mainService": {
        "uri": "/service/OrderService/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.0"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "managebooksandorders-display": {
          "semanticObject": "managebooksandorders",
          "action": "display",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.146.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "bookshop.createorders.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "OrdersList",
          "target": "OrdersList"
        },
        {
          "pattern": "Orders({key}):?query:",
          "name": "OrdersObjectPage",
          "target": "OrdersObjectPage"
        }
      ],
      "targets": {
        "OrdersList": {
          "type": "Component",
          "id": "OrdersList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "enhanceI18n": "i18n/custom_i18n.properties",
              "contextPath": "/Orders",
              "variantManagement": "Page",
              "navigation": {
                "Orders": {
                  "detail": {
                    "route": "OrdersObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable",
                    "quickVariantSelection": {
                      "showCounts": true
                    },
                    "selectionMode": "None",
                    "selectAll": false
                  },
                  "columns": {
                    "DataField::orderNumber": {
                      "width": "100%"
                    },
                    "DataField::totalPrice": {
                      "width": "100%"
                    },
                    "DataField::status_code": {
                      "width": "100%"
                    }
                  }
                }
              },
              "initialLoad": "Enabled"
            }
          }
        },
        "OrdersObjectPage": {
          "type": "Component",
          "id": "OrdersObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "enhanceI18n": "i18n/custom_i18n.properties",
              "editableHeaderContent": false,
              "contextPath": "/Orders",
              "navigation": {},
              "controlConfiguration": {
                "orderItems/@com.sap.vocabularies.UI.v1.LineItem#OrderItems": {
                  "columns": {
                    "DataField::book_ID": {
                      "width": "100%"
                    },
                    "DataField::quantity": {
                      "width": "100%"
                    },
                    "DataField::book::author": {
                      "width": "100%"
                    },
                    "DataField::book::genre::name": {
                      "width": "100%"
                    }
                  }
                },
                "orderlog/@com.sap.vocabularies.UI.v1.LineItem#OrderTracking": {
                  "columns": {
                    "DataField::status_code": {
                      "width": "100%"
                    },
                    "DataField::trackingInfo": {
                      "width": "100%"
                    },
                    "DataField::createdAt": {
                      "width": "100%"
                    }
                  }
                }
              },
              "content": {
                "header": {
                  "actions": {
                    "downloadPDF": {
                      "press": "bookshop.createorders.ext.controller.DownloadPDF.downloadPFDCustomAction",
                      "visible": "{= %{status_code} === 'DELIVERED'}",
                      "enabled": true,
                      "text": "Download PDF"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.cloud": {
    "public": true,
    "service": "CAPsample.service"
  }
}

{
  "name": "CAP-sample",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/cds-common-content": "^3.1.0",
    "@sap/xssec": "^4",
    "blob-stream": "^0.1.3",
    "express": "^4",
    "jest": "^30.3.0",
    "pdfkit": "^0.18.0"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^0",
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0",
    "mbt": "^1.2.29",
    "rimraf": "^5.0.5"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-managebooks": "cds watch --open bookshop.managebooksandorders/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-managebooksandorders": "cds watch --open bookshop.managebooksandorders/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy CAP-bookshop --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1",
    "watch-manageorders": "cds watch --open bookshop.createorders/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-createorders": "cds watch --open bookshop.createorders/index.html?sap-ui-xx-viewCache=false --livereload false",
    "test": "jest"
  },
  "private": true,
  "cds": {
    "sql": {
      "native_hana_associations": false
    },
    "requires": {
      "[production]": {
        "auth": "xsuaa",
        "db": "hana"
      },
      "auth": {
        "[development]": {
          "kind": "mocked",
          "users": {
            "admin": {
              "password": "admin",
              "roles": [
                "Admin",
                "User"
              ]
            },
            "user": {
              "password": "user",
              "roles": [
                "User"
              ]
            },
            "candice": {
              "password": "candice",
              "roles": [
                "User"
              ]
            },
            "bob": {
              "password": "bob",
              "roles": [
                "Admin",
                "User"
              ]
            }
          }
        }
      },
      "destinations": true,
      "html5-repo": true,
      "workzone": true
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/managebooksandorders",
    "app/createorders"
  ]
}

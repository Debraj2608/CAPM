{
  "name": "CAP-sample",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "express": "^4",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0",
    "rimraf": "^5.0.5",
    "mbt": "^1.2.29"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-managebooks": "cds watch --open bookshop.managebooks/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy CAP-bookshop --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1"
  },
  "private": true,
  "cds": {
    "sql": {
      "native_hana_associations": false
    },
    "requires": {
      "[production]": {
        "auth": "xsuaa",
        "db": "hana"
      },
      "auth": {
        "[development]": {
          "kind": "mocked",
          "users": {
            "admin": {
              "password": "admin",
              "roles": [
                "Admin",
                "User"
              ]
            },
            "user": {
              "password": "user",
              "roles": [
                "User"
              ]
            },
            "candice": {
              "password": "candice",
              "roles": [
                "User"
              ]
            },
            "bob": {
              "password": "bob",
              "roles": [
                "Admin",
                "User"
              ]
            }
          }
        }
      },
      "destinations": true
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/managebooks"
  ]
}
